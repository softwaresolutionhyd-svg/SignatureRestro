# Copy to .env.deploy and fill with same values as GitHub repo Secrets.
# Used by deploy-ftp-local.bat when GitHub Actions is slow/down.
FTP_SERVER=ftp.your-host.com
FTP_USERNAME=your-ftp-user
FTP_PASSWORD=your-ftp-password
FTP_SERVER_DIR=/public_html/

# Optional: auto-migrate after FTP upload (same as GitHub Secrets)
DEPLOY_KEY=your-long-random-secret
DEPLOY_MIGRATE_URL=https://signature.softwaresolutions.pk/deploy/hooks/migrate
