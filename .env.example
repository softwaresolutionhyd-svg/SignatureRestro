APP_NAME=Signature
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://signature.softwaresolutions.pk
APP_TIMEZONE=Asia/Karachi

# Fixed LAN IP for Order Taker app + tablets on cafe WiFi
LAN_SERVER_IP=192.168.3.50
LAN_SERVER_URL=http://192.168.3.50

# Production (live server) — recommended:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://signature.softwaresolutions.pk
# SESSION_LIFETIME=60
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Signature
DB_USERNAME=root
DB_PASSWORD=

# Online / offline cloud sync
# Local cafe PC: SYNC_ROLE=local, SYNC_REMOTE_URL=https://your-subdomain.example.com
# Hosting:       SYNC_ROLE=cloud, SYNC_REMOTE_URL can be empty
SYNC_ENABLED=false
SYNC_ROLE=local
SYNC_REMOTE_URL=
SYNC_TOKEN=
SYNC_BATCH_SIZE=100
SYNC_HEARTBEAT_SECONDS=60
SYNC_AUTO_PUSH_HEARTBEAT=true
SYNC_AUTO_PULL=true
SYNC_PULL_TABLES=*
SYNC_PULL_LOOKBACK_DAYS=120
SYNC_PUSH_TIMEOUT_SECONDS=30
SYNC_PUSH_DEBOUNCE_SECONDS=60

# Optional: full path to mysqldump for faster super_admin backups (Windows e.g. C:\laragon\bin\mysql\mysql-8.0.30-winx64\bin\mysqldump.exe)
# MYSQLDUMP_PATH=mysqldump

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
